# backend-chat
BACKEND_CHAT_ADDR=:9090
BACKEND_CHAT_DB=./chat.db
BACKEND_MODEL=anthropic/claude-sonnet-4-20250514
BACKEND_LLM_PROVIDER=anthropic

# provider keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=

# centrifugo
CENTRIFUGO_API_URL=http://localhost:8000/api
CENTRIFUGO_API_KEY=backend-chat-dev-api-key

# sandbox (OpenSandbox server — start with: ./sandbox-files-init/start.sh)
OPEN_SANDBOX_DOMAIN=localhost:8080
OPEN_SANDBOX_PROTOCOL=http
OPEN_SANDBOX_API_KEY=dev-test-key

# Cloudflare R2 — artifact binary storage (optional)
# When set, artifact content is also stored in R2 for CDN delivery.
# Text content is always in SQLite regardless.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_KEY=
R2_BUCKET=artifacts
R2_PUBLIC_URL=https://pub-xxx.r2.dev



# Extended thinking (deep-work mode only)
THINKING_BUDGET=10000

# Voyage AI for hybrid memory search (optional — falls back to LocalEmbedder)
VOYAGE_API_KEY=

# Memory root (already exists)
BACKEND_MEMORY_ROOT=./memory
