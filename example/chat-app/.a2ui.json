{
  "version": "1.0.0",
  "project": {
    "name": "chat-app",
    "description": "AI Chat Application with a2ui components"
  },
  "theme": {
    "name": "default",
    "colors": {
      "primary": "#3b82f6",
      "secondary": "#8b5cf6",
      "accent": "#ec4899",
      "background": "#ffffff",
      "surface": "#f3f4f6",
      "text": "#111827",
      "textMuted": "#6b7280",
      "border": "#e5e7eb",
      "error": "#ef4444",
      "success": "#10b981",
      "warning": "#f59e0b",
      "info": "#06b6d4"
    },
    "typography": {
      "fontFamily": "inter, system-ui, sans-serif",
      "fontSize": {
        "xs": "0.75rem",
        "sm": "0.875rem",
        "base": "1rem",
        "lg": "1.125rem",
        "xl": "1.25rem",
        "2xl": "1.5rem"
      }
    },
    "spacing": {
      "unit": "4px",
      "scale": [0, 1, 2, 4, 8, 12, 16, 24, 32, 48, 64]
    }
  },
  "components": {
    "button": {
      "variants": ["default", "outline", "ghost", "destructive"],
      "sizes": ["xs", "sm", "md", "lg"]
    },
    "card": {
      "shadow": true,
      "rounded": true
    },
    "input": {
      "bordered": true,
      "rounded": true
    }
  },
  "accessibility": {
    "contrastRatio": "WCAG_AA",
    "focusStyle": "ring",
    "reduceMotion": false
  },
  "development": {
    "debug": false,
    "logComponents": false,
    "validateProps": true
  }
}
